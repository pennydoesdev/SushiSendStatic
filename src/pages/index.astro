---
import Base from '../layouts/Base.astro';
---

<Base title="Modern email platform">
  <section style="text-align: center; padding: 3rem 0;">
    <span class="eyebrow">Phase 0 — scaffolded</span>
    <h1>Email that just sends.</h1>
    <p
      style="font-size: 1.25rem; color: var(--color-text-secondary); max-width: 640px; margin: 1rem auto 2rem;"
    >
      A Cloudflare-first, Amazon SES-powered email platform for transactional sending and
      lightweight marketing — with automatic domain onboarding and built-in deliverability
      intelligence.
    </p>
    <a href="/pricing" class="cta">See pricing</a>
  </section>

  <section style="margin-top: 4rem;">
    <h2>What's coming</h2>
    <ul>
      <li>Automatic SES domain verification with Cloudflare DNS</li>
      <li>Visual email builder with versioned templates</li>
      <li>Contacts, tags, lists, and dynamic segments</li>
      <li>Searchable docs with an AI helper grounded in our content</li>
      <li>Stripe billing with a dedicated IP add-on</li>
      <li>WordPress plugin and a clean public API</li>
    </ul>
  </section>
</Base>
